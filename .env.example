# Copy this file to .env and add your own key locally.
# Never commit .env or share its value in chat.
OPENAI_API_KEY=
# Set to false on the public demo to pause paid OpenAI features while keeping Try guided demo available.
LIVE_ANALYSIS_ENABLED=true
# Maximum paid AI requests allowed from one IP address in one hour.
MAX_REQUESTS_PER_HOUR=10
